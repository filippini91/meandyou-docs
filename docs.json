{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "me&you Help Center",
  "description": "Plain-language guides for planning your wedding with me&you — from creating your account to building your guest list, wedding website, and RSVPs.",
  "colors": {
    "primary": "#9D2A39",
    "light": "#D95A61",
    "dark": "#8A2737"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": [
      "copy",
      "assistant",
      "download-pdf",
      "claude",
      "chatgpt"
    ],
    "display": "header"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Contact us",
          "icon": "life-buoy",
          "href": "mailto:support@meandyou.wedding"
        },
        {
          "anchor": "Changelog",
          "icon": "scroll-text",
          "href": "/changelog"
        }
      ]
    },
    "groups": [
      {
        "group": "Getting Started",
        "icon": "door-open",
        "pages": [
          "getting-started/signing-in",
          "getting-started/creating-your-account",
          "getting-started/verifying-your-email-and-finishing-your-profile",
          "getting-started/resetting-a-forgotten-password",
          "getting-started/starting-your-wedding-plan"
        ]
      },
      {
        "group": "Your Account",
        "icon": "user-round",
        "pages": [
          "your-account/profile",
          "your-account/security",
          "your-account/notification-preferences",
          "your-account/privacy"
        ]
      },
      {
        "group": "Planning Your Wedding",
        "icon": "heart",
        "pages": [
          "planning/overview",
          "planning/messages",
          "planning/inspiration-board",
          "planning/tasks-and-checklist",
          "planning/budget-and-expenses",
          "planning/calculator",
          "planning/schedule",
          "planning/file-storage",
          "planning/wedding-settings-plan-and-billing"
        ]
      },
      {
        "group": "Guest management",
        "icon": "users-round",
        "pages": [
          "guest-experience/overview",
          "guest-experience/building-your-guest-list",
          "guest-experience/wedding-website",
          "guest-experience/digital-invitation",
          "guest-experience/questionnaire",
          "guest-experience/media-uploads",
          "guest-experience/announcements",
          "guest-experience/guest-feed",
          "guest-experience/seating-chart"
        ]
      },
      {
        "group": "For Your Guests",
        "icon": "mail-heart",
        "pages": [
          "for-your-guests/finding-your-invitation",
          "for-your-guests/responding-to-the-questionnaire",
          "for-your-guests/viewing-the-wedding-website",
          "for-your-guests/sharing-your-photos-and-videos",
          "for-your-guests/arranging-a-carpool",
          "for-your-guests/suggesting-songs",
          "for-your-guests/posting-to-the-feed"
        ]
      },
      {
        "group": "About These Docs",
        "icon": "pencil-line",
        "hidden": true,
        "pages": [
          "about-these-docs/how-we-write-these-guides"
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/light.svg",
    "dark": "/images/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Open me&you",
      "href": "https://meandyou.wedding/plan"
    }
  },
  "footer": {
    "socials": {
      "instagram": "https://instagram.com/meandyou.wedding"
    }
  },
  "background": {
    "color": {
      "light": "#FAFAF9",
      "dark": "#1C1917"
    }
  },
  "fonts": {
    "family": "Geist"
  }
}
